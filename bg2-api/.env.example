# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Anthropic console — used for Claude + Voyage embeddings

# ── Auth ──────────────────────────────────────────────────────────────────────
API_KEY=                              # Any strong random string (e.g. openssl rand -hex 32)
                                      # Must match VITE_API_KEY in the frontend
                                      # Leave empty to disable auth in local dev

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=https://xxx.cloud.qdrant.io:6333   # Qdrant Cloud cluster URL
QDRANT_API_KEY=eyJ...                          # Qdrant Cloud API key
# QDRANT_PATH=./data/qdrant            # Local file-based DB (dev only — omit if using Cloud)

# ── TTS (optional) ────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_...             # ElevenLabs dashboard → Profile → API Keys
ELEVENLABS_VOICE_ID=                  # ElevenLabs voice library ID for the chosen voice

# ── Model config (defaults shown) ─────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173  # Comma-separated in prod: https://your-app.vercel.app
