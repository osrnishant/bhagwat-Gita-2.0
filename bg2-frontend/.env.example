# Backend API URL (set to your Railway URL in production)
VITE_API_URL=https://bhagwat-gita-20-production.up.railway.app

# Shared secret — must match API_KEY in Railway environment variables
# Generate with: openssl rand -hex 32
VITE_API_KEY=your-shared-api-key-here

# Umami Analytics — sign up free at umami.is, add your Vercel domain, paste the Website ID
VITE_UMAMI_WEBSITE_ID=your-umami-website-id-here
